# ASAAS Configuration (para funcionalidades de pagamento PIX)
ASAAS_API_KEY=seu_token_asaas_aqui
ASAAS_URL=https://api.asaas.com/v3

# Firebase Configuration
# Use prefixo VITE_ para variáveis de ambiente acessíveis no browser com import.meta.env
VITE_FIREBASE_API_KEY=sua_chave_api_firebase
VITE_FIREBASE_AUTH_DOMAIN=seu_projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu_projeto_id
VITE_FIREBASE_STORAGE_BUCKET=seu_projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=seu_messaging_sender_id
VITE_FIREBASE_APP_ID=seus_app_ids
